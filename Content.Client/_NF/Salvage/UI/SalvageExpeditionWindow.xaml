<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'salvage-expedition-window-title'}"
                      MinSize="800 420">
    <BoxContainer Orientation="Vertical">
        <BoxContainer Orientation="Horizontal" Name="ProgressionBox" Visible="False">
            <Label Name="ProgressionLabel"
                   Text="{Loc 'salvage-expedition-window-progression'}"
                   SetWidth="96"
                   Margin="5"/>
            <ProgressBar Name="ProgressionBar"
                         HorizontalExpand="True"
                         MinValue="0"
                         MaxValue="1"
                         SetHeight="25"/>
            <Label Name="ProgressionText" Text="00:00"
                   Margin="5"/>
        </BoxContainer>
        <BoxContainer Orientation="Horizontal">
            <Label Name="NextOfferLabel"
                   Text="{Loc 'salvage-expedition-window-next'}"
                   SetWidth="210"
                   Margin="5"/>
            <ProgressBar Name="NextOfferBar"
                         HorizontalExpand="True"
                         MinValue="0"
                         MaxValue="1"
                         SetHeight="25"/>
            <Label Name="NextOfferText" Text="0.00"
                   SetWidth="50"
                   HorizontalAlignment="Right"
                   Margin="5"/>
        </BoxContainer>
        <BoxContainer Orientation="Horizontal" Margin="0 2 0 0" />
        <BoxContainer Orientation="Horizontal" Margin="5 6 5 4">
            <Label Name="ActiveCountLabel"
                   Text="{Loc 'salvage-expedition-window-active-count'}"
                   SetHeight="20"/>
            <Label Name="ActiveCountValue"
                   Text="0"
                   Margin="5 0 15 0"
                   SetHeight="20"/>
            <Label Name="QueueCountLabel"
                   Text="{Loc 'salvage-expedition-window-queue-count'}"
                   Margin="10 0 0 0"
                   SetHeight="20"/>
            <Label Name="QueueCountValue"
                   Text="0"
                   Margin="5 0 0 0"
                   SetHeight="20"/>
            <BoxContainer Orientation="Horizontal" Name="ConfirmBox" Visible="False" Margin="10 0 0 0">
                <Label Name="ConfirmText" Text="00:00"
                       SetWidth="50"
                       HorizontalAlignment="Right"
                       Margin="0 0 5 0"/>
                <ProgressBar Name="ConfirmBar"
                             SetWidth="140"
                             MinValue="0"
                             MaxValue="1"
                             SetHeight="20"/>
            </BoxContainer>
            <Control HorizontalExpand="True" />
            <Button Name="Confirm"
                    Text="{Loc 'salvage-expedition-window-confirm'}"
                    Disabled="True"
                    Margin="0 0 5 0"/>
            <Button Name="Cancel"
                    Text="{Loc 'salvage-expedition-window-cancel'}"
                    Disabled="True"/>
        </BoxContainer>
        <controls:HLine Color="#404040" Thickness="2" Margin="0 5 0 5"/>
        <BoxContainer Name="Container"
                      Orientation="Horizontal"
                      Margin="5 0 5 0"/>
        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5 0 0">
            <Button Name="Finish"
                    Text="{Loc 'salvage-expedition-window-finish'}"
                    Margin="0 0 0 0"/>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
